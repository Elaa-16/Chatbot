    """CREATE: Submit a new leave request"""
    cursor = db.cursor()
    
    # Verify the employee is requesting for themselves (unless CEO/Manager helping)
    if user["role"] == "employee" and leave_request.employee_id != user["employee_id"]:
        raise HTTPException(
            status_code=status.HTTP_403_FORBIDDEN,
