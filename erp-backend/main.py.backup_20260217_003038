@app.get("/employees", response_model=List[Employee])
def get_employees(user: dict = Depends(authenticate_user), db = Depends(get_db)):
    """READ: Get all accessible employees"""
    cursor = db.cursor()
    
    if user["role"] == "ceo":
        cursor.execute("SELECT * FROM employees")
    elif user["role"] == "manager":
        supervised = user["supervised_employees"] + [user["employee_id"]]
        placeholders = ','.join(['?' for _ in supervised])
        cursor.execute(
            f"SELECT * FROM employees WHERE employee_id IN ({placeholders})",
            supervised
        )
    else:
        cursor.execute(
            "SELECT * FROM employees WHERE employee_id = ?",
            (user["employee_id"],)
        )
    
    employees = cursor.fetchall()
