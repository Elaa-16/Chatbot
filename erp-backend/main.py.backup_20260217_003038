# Database connection
DB_PATH = "erp_database.db"

def get_db():
    """Get database connection"""
    conn = sqlite3.connect(DB_PATH, check_same_thread=False)  # ← Ajoutez check_same_thread=False
    conn.row_factory = sqlite3.Row
    try:
        yield conn
    finally:
        conn.close()

